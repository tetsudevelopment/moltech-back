# === Runtime ===
# development | staging | production | test
NODE_ENV=development
PORT=3000
# debug | info | warn | error
LOG_LEVEL=info

# === Database (Postgres) ===
# Used by both docker-compose and the app (via Prisma)
POSTGRES_USER=moltech
POSTGRES_PASSWORD=change-me-in-development
POSTGRES_DB=moltech_dev
# Prisma reads DATABASE_URL at runtime and at migration time
DATABASE_URL=postgresql://moltech:change-me-in-development@localhost:5432/moltech_dev?schema=public&sslmode=disable
# Separate user with migration privileges (superuser or CREATEDB)
MIGRATION_DATABASE_URL=postgresql://moltech_migrator:change-me-in-development@localhost:5432/moltech_dev?schema=public&sslmode=disable

# === Redis ===
# Use rediss:// with password for TLS in production
REDIS_URL=redis://localhost:6379

# === JWT (RS256) ===
# Generate a dev RSA keypair with: pnpm tsx scripts/generate-jwt-keys.ts
# Paste the output below — both keys as single-line strings with \n escapes preserved
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# Access token TTL (stateless, short-lived)
JWT_ACCESS_TTL=15m
# Refresh token TTL (opaque UUID stored as SHA-256 hash in DB)
JWT_REFRESH_TTL=30d
JWT_ISSUER=moltech-api
JWT_AUDIENCE=moltech-mobile

# === OAuth providers ===
# Android and iOS have separate client IDs for OIDC validation
GOOGLE_OAUTH_CLIENT_ID_ANDROID=
GOOGLE_OAUTH_CLIENT_ID_IOS=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# === Email (Resend) ===
RESEND_API_KEY=re_change_me
RESEND_FROM_EMAIL=no-reply@moltech.app

# === Payment gateway ===
# paymentsway | mock
PAYMENT_GATEWAY=mock
PAYMENTSWAY_BASE_URL=https://api.paymentsway.example
PAYMENTSWAY_API_KEY=
PAYMENTSWAY_WEBHOOK_SECRET=
# Controls mock adapter behavior: always_approve | always_decline | random
MOCK_GATEWAY_BEHAVIOR=always_approve

# === Security ===
# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,moltech://*
# Argon2id params - OWASP recommended minimums
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# === Rate limiting ===
# Window size in seconds
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# === Observability ===
SENTRY_DSN=
# development | staging | production
SENTRY_ENVIRONMENT=development
# Fraction of errors to send (0.0-1.0)
SENTRY_SAMPLE_RATE=1.0
# Fraction of transactions to trace (keep low in production)
SENTRY_TRACES_SAMPLE_RATE=0.1
