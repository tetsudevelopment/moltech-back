generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model audit_log {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action      String   @db.VarChar(100)
  actor       String   @db.VarChar(50)
  target_type String?  @db.VarChar(50)
  target_id   String?  @db.VarChar(200)
  request_id  String?  @db.VarChar(100)
  ip          String?  @db.VarChar(45)
  metadata    Json?    @db.JsonB
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([action], map: "idx_audit_log_action")
  @@index([actor], map: "idx_audit_log_actor")
  @@index([created_at(sort: Desc)], map: "idx_audit_log_created_at")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model coupons {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String             @unique @db.VarChar(50)
  description    String?            @db.VarChar(200)
  discount_type  coupon_type_enum
  discount_value Decimal            @db.Decimal(10, 2)
  start_date     DateTime           @db.Timestamptz(6)
  end_date       DateTime           @db.Timestamptz(6)
  max_uses       Int?
  current_uses   Int                @default(0)
  status         coupon_status_enum @default(active)
  rentals        rentals[]

  @@index([code], map: "idx_coupons_code")
  @@index([start_date, end_date], map: "idx_coupons_dates")
  @@index([status], map: "idx_coupons_status")
}

model notifications {
  id      String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id String                 @db.Uuid
  title   String                 @db.VarChar(150)
  body    String
  type    notification_type_enum @default(system)
  is_read Boolean                @default(false)
  sent_at DateTime               @default(now()) @db.Timestamptz(6)
  users   users                  @relation(fields: [user_id], references: [id], map: "fk_notification_user")

  @@index([sent_at], map: "idx_notifications_sent_at")
  @@index([user_id, is_read], map: "idx_notifications_unread")
  @@index([user_id], map: "idx_notifications_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model payment_methods {
  id               String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String                     @db.Uuid
  type             payment_method_type_enum
  cardholder_name  String                     @db.VarChar(150)
  last_four_digits String                     @db.Char(4)
  expiry_month     Int                        @db.SmallInt
  expiry_year      Int                        @db.SmallInt
  is_default       Boolean                    @default(false)
  gateway_token    String                     @db.VarChar(300)
  status           payment_method_status_enum @default(active)
  created_at       DateTime                   @default(now()) @db.Timestamptz(6)
  users            users                      @relation(fields: [user_id], references: [id], map: "fk_payment_method_user")
  payments         payments[]
  rentals          rentals[]

  @@index([user_id, is_default], map: "idx_payment_methods_default")
  @@index([status], map: "idx_payment_methods_status")
  @@index([user_id], map: "idx_payment_methods_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model payments {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rental_id         String               @db.Uuid
  user_id           String               @db.Uuid
  payment_method_id String?              @db.Uuid
  concept           payment_concept_enum @default(rental)
  amount            Decimal              @db.Decimal(10, 2)
  currency          String               @default("COP") @db.VarChar(10)
  gateway           payment_gateway_enum
  transaction_id    String               @db.VarChar(200)
  merchant_id       String?              @db.VarChar(200)
  status            payment_status_enum  @default(pending)
  gateway_message   String?
  attempted_at      DateTime             @default(now()) @db.Timestamptz(6)
  updated_at        DateTime             @default(now()) @db.Timestamptz(6)
  payment_methods   payment_methods?     @relation(fields: [payment_method_id], references: [id], map: "fk_payment_method")
  rentals           rentals              @relation(fields: [rental_id], references: [id], map: "fk_payment_rental")
  users             users                @relation(fields: [user_id], references: [id], map: "fk_payment_user")

  @@unique([gateway, transaction_id], map: "uq_payments_gateway_transaction")
  @@index([attempted_at(sort: Desc)], map: "idx_payments_attempted_at")
  @@index([payment_method_id], map: "idx_payments_method")
  @@index([rental_id], map: "idx_payments_rental")
  @@index([status], map: "idx_payments_status")
  @@index([user_id], map: "idx_payments_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model power_banks {
  id            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String                 @unique @db.VarChar(20)
  station_id    String                 @db.Uuid
  model         String?                @db.VarChar(100)
  status        power_bank_status_enum @default(available)
  battery_level Int                    @default(100)
  qr_code       String                 @unique @db.VarChar(300)
  created_at    DateTime               @default(now()) @db.Timestamptz(6)
  updated_at    DateTime               @default(now()) @db.Timestamptz(6)
  stations      stations               @relation(fields: [station_id], references: [id], map: "fk_power_bank_station")
  rentals       rentals[]

  @@index([code], map: "idx_power_banks_code")
  @@index([station_id], map: "idx_power_banks_station")
  @@index([status], map: "idx_power_banks_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model rentals {
  id                       String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                  String             @db.Uuid
  power_bank_id            String             @db.Uuid
  pickup_station_id        String             @db.Uuid
  coupon_id                String?            @db.Uuid
  payment_method_id        String             @db.Uuid
  start_time               DateTime           @default(now()) @db.Timestamptz(6)
  end_time                 DateTime?          @db.Timestamptz(6)
  estimated_duration_hours Int
  actual_duration_hours    Decimal?           @db.Decimal(5, 2)
  hourly_rate              Decimal            @db.Decimal(10, 2)
  estimated_cost           Decimal            @db.Decimal(10, 2)
  final_cost               Decimal?           @db.Decimal(10, 2)
  currency                 String             @default("COP") @db.VarChar(10)
  discount_applied         Decimal            @default(0) @db.Decimal(10, 2)
  penalty                  Decimal            @default(0) @db.Decimal(10, 2)
  status                   rental_status_enum @default(active)
  created_at               DateTime           @default(now()) @db.Timestamptz(6)
  payments                 payments[]
  coupons                  coupons?           @relation(fields: [coupon_id], references: [id], map: "fk_rental_coupon")
  payment_methods          payment_methods    @relation(fields: [payment_method_id], references: [id], map: "fk_rental_payment_method")
  stations                 stations           @relation(fields: [pickup_station_id], references: [id], map: "fk_rental_pickup_station")
  power_banks              power_banks        @relation(fields: [power_bank_id], references: [id], map: "fk_rental_power_bank")
  users                    users              @relation(fields: [user_id], references: [id], map: "fk_rental_user")

  @@index([user_id, status], map: "idx_rentals_active")
  @@index([coupon_id], map: "idx_rentals_coupon")
  @@index([payment_method_id], map: "idx_rentals_payment_method")
  @@index([pickup_station_id], map: "idx_rentals_pickup_station")
  @@index([power_bank_id], map: "idx_rentals_power_bank")
  @@index([start_time], map: "idx_rentals_start_time")
  @@index([status], map: "idx_rentals_status")
  @@index([user_id], map: "idx_rentals_user")
}

model stations {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String              @db.VarChar(150)
  city           String              @db.VarChar(80)
  zone           String?             @db.VarChar(100)
  address        String              @db.VarChar(200)
  latitude       Decimal             @db.Decimal(10, 7)
  longitude      Decimal             @db.Decimal(10, 7)
  hourly_rate    Decimal             @db.Decimal(10, 2)
  currency       String              @default("COP") @db.VarChar(10)
  total_capacity Int                 @default(0)
  status         station_status_enum @default(online)
  description    String?
  opening_time   DateTime?           @db.Time(6)
  closing_time   DateTime?           @db.Time(6)
  created_at     DateTime            @default(now()) @db.Timestamptz(6)
  power_banks    power_banks[]
  rentals        rentals[]

  @@index([city], map: "idx_stations_city")
  @@index([latitude, longitude], map: "idx_stations_coordinates")
  @@index([status], map: "idx_stations_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name          String                @db.VarChar(100)
  last_name           String                @db.VarChar(100)
  email               String?               @unique @db.VarChar(150)
  phone               String?               @unique @db.VarChar(20)
  password_hash       String?               @db.VarChar(255)
  country             String?               @db.VarChar(80)
  city                String?               @db.VarChar(80)
  address             String?               @db.VarChar(200)
  photo_url           String?               @db.VarChar(300)
  rating              Decimal?              @db.Decimal(2, 1)
  email_verified      Boolean               @default(false)
  phone_verified      Boolean               @default(false)
  accepted_policy     Boolean               @default(false)
  auth_provider       auth_provider_enum    @default(email)
  auth_provider_id    String?               @db.VarChar(200)
  role                user_role_enum        @default(user)
  status              user_status_enum      @default(active)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  notifications       notifications[]
  payment_methods     payment_methods[]
  payments            payments[]
  rentals             rentals[]
  verification_tokens verification_tokens[]

  @@index([auth_provider, auth_provider_id], map: "idx_users_auth")
  @@index([email], map: "idx_users_email")
  @@index([phone], map: "idx_users_phone")
  @@index([status], map: "idx_users_status")
}

model verification_tokens {
  id            String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String                       @db.Uuid
  type          verification_token_type_enum
  token         String                       @db.VarChar(10)
  expires_at    DateTime                     @db.Timestamptz(6)
  used          Boolean                      @default(false)
  attempts_used Int                          @default(0)
  created_at    DateTime                     @default(now()) @db.Timestamptz(6)
  users         users                        @relation(fields: [user_id], references: [id], map: "fk_verification_token_user")

  @@index([expires_at], map: "idx_verification_tokens_expiry")
  @@index([user_id, type, token], map: "idx_verification_tokens_lookup")
  @@index([user_id], map: "idx_verification_tokens_user")
}

enum auth_provider_enum {
  email
  google
  facebook
}

enum coupon_status_enum {
  active
  expired
  disabled
}

enum coupon_type_enum {
  percentage
  fixed_amount
}

enum notification_type_enum {
  promotion
  rental
  payment
  system
}

enum payment_concept_enum {
  rental
  penalty
  refund
}

enum payment_gateway_enum {
  wompi
  payu
  mercadopago
  stripe
  other
}

enum payment_method_status_enum {
  active
  expired
  deleted
}

enum payment_method_type_enum {
  visa
  mastercard
  amex
  dinersclub
  other
}

enum payment_status_enum {
  pending
  approved
  rejected
  refunded
  error
}

enum power_bank_status_enum {
  available
  rented
  charging
  damaged
  retired
}

enum rental_status_enum {
  active
  completed
  cancelled
  penalized
}

enum station_status_enum {
  online
  offline
  maintenance
}

enum user_role_enum {
  user
  admin
  superadmin
}

enum user_status_enum {
  active
  suspended
  inactive
  pending_verification
}

enum verification_token_type_enum {
  email
  whatsapp
  reset_password
}
